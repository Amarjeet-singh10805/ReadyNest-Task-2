{
  "name": "campus-sync",
  "version": "1.0.0",
  "description": "Smart Campus Utility App",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run --prefix frontend build",
    "start": "node backend/server.js",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "node backend/server.js",
    "dev:frontend": "npm run --prefix frontend dev",
    "setup": "npm run install:all && node backend/seed.js",
    "seed": "node backend/seed.js"
  }
}
